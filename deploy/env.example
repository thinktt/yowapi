# Copy this file to deploy/.env for local/deploy Compose runs.
#
# Compose reads deploy/.env for variable substitution. The compose file then
# passes only the variables each container needs.

# Used by the NATS server auth command and by yowapi when connecting to NATS.
NATS_TOKEN=replace_with_long_random_token
NATS_URL=nats://nats:4222

# Used by yowapi for signing API JWTs.
JWT_KEY=replace_with_long_random_jwt_signing_key

# Optional: Lichess account ID that should receive the admin role.
ADMIN_USER=your_lichess_username

# Optional: required only for API paths that import/export games through Lichess.
LICHESS_TOKEN=replace_with_lichess_api_token
